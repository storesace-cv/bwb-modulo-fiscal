### 422
POST https://sandbox.fiscalmod.bwb.pt/v1/documents
Content-Type: application/json
Idempotency-Key: 44444444-4444-4444-8444-444444444444
Authorization: Bearer REPLACE_WITH_MODULE_SANDBOX_TOKEN

{"external_id":"invalid-demo","document_type":"invoice","currency":"INVALID","issued_at":"2026-07-21T10:00:00+01:00","seller":{"tax_id":"FIXTURE-NIF-AO-0001","name":"S"},"lines":[{"line_id":"L1","description":"d","quantity":"1","unit_price":"1.00","tax_code":"NOR"}]}
