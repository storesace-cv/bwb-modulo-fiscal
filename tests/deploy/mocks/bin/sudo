#!/usr/bin/env bash
# Mock sudo: record and execute without privilege escalation.
# Only reachable from mocked remote commands (never required on the operator Mac).
set -Eeuo pipefail

: "${DEPLOY_MOCK_LOG:?DEPLOY_MOCK_LOG required}"

# Drop non-interactive flag used by deploy scripts.
if [[ "${1:-}" == "-n" ]]; then
  shift
fi

printf 'sudo %s\n' "$*" >>"${DEPLOY_MOCK_LOG}"

# Ownership changes are simulated (no root on CI/macOS runners).
if [[ "${1:-}" == "chown" ]]; then
  exit 0
fi

if [[ "${1:-}" == "install" ]]; then
  # Rewrite install to ignore -o/-g while preserving mode and paths.
  out=()
  skip=0
  for a in "$@"; do
    if [[ "${skip}" -eq 1 ]]; then
      skip=0
      continue
    fi
    case "${a}" in
      -o | -g)
        skip=1
        continue
        ;;
      *)
        out+=("${a}")
        ;;
    esac
  done
  exec "${out[@]}"
fi

exec "$@"
