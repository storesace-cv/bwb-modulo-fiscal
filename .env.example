# Example / template only — no real secrets.
# Copy to ignored files locally (chmod 600):
#   .env.local          — SSH/deploy operator params (key PATH only)
#   .env.deploy.local   — runtime allowlist values → fiscal.env on server
#   .env.migrate.local  — migration DSN → migrate.env on server
#   .env.admin.local    — admin DSN → admin.env on server (root:root 0600; env -i only)
#
# Never commit .env.local / .env.deploy.local / .env.migrate.local / .env.admin.local.
# Never put private keys, passwords, or live DSNs in the repository.
# Rotate FISCAL_AUTH_DEV_TOKEN when compromised or when operators leave.
#
# Staging hostname: sandbox.fiscalmod.bwb.pt (not fiscalmod.bwb.pt).
# Operational label: staging. Homologation must use FISCAL_AUTH_MODE=credential_store
# (dev_static is rejected outside development).

# --- .env.local (operator; not transferred to fiscal.env) ---
DEPLOY_HOST=REPLACE_WITH_STAGING_IP_OR_HOSTNAME
DEPLOY_USER=REPLACE_WITH_SUDO_USER
DEPLOY_SSH_KEY=~/.ssh/REPLACE_WITH_KEY_FILENAME
DEPLOY_KNOWN_HOSTS=~/.ssh/bwb_fiscal_staging_known_hosts
EXPECTED_COMMIT=REPLACE_WITH_FULL_GIT_SHA
DEPLOY_GOARCH=amd64
# Optional: set to 1 to exercise scripts without SSH
# DEPLOY_DRY_RUN=1
# Optional: prove N-1 binary/schema compatibility before post-migration auto rollback
# DEPLOY_N1_COMPAT_PROVEN=0

# --- .env.deploy.local → /etc/bwb-modulo-fiscal/fiscal.env (runtime role) ---
FISCAL_HTTP_ADDR=127.0.0.1:8080
FISCAL_APP_VERSION=0.0.0-staging
FISCAL_PACKAGE=AO-UNDECLARED
FISCAL_HTTP_READ_TIMEOUT=5s
FISCAL_HTTP_READ_HEADER_TIMEOUT=5s
FISCAL_HTTP_WRITE_TIMEOUT=10s
FISCAL_HTTP_IDLE_TIMEOUT=60s
FISCAL_HTTP_SHUTDOWN_TIMEOUT=10s
# Local development with static bearer (never homologation):
FISCAL_ENV=development
FISCAL_AUTH_MODE=dev_static
FISCAL_AUTH_DEV_TOKEN=REPLACE_WITH_TOKEN_AT_LEAST_32_BYTES
FISCAL_AUTH_DEV_SCOPE_ID=REPLACE_WITH_SCOPE_ID
FISCAL_AUTH_DEV_TAXPAYER_NIF=REPLACE_WITH_SYNTHETIC_NIF
FISCAL_SCOPE_TIMEZONE=Africa/Luanda
FISCAL_SERIES_MODE=static
FISCAL_SERIES_EFFECTIVE_CODE=A
# Homologation / sandbox credential_store (uncomment; do not set FISCAL_AUTH_DEV_*):
# FISCAL_ENV=homologation
# FISCAL_AUTH_MODE=credential_store
FISCAL_DATABASE_DRIVER=postgres
FISCAL_DATABASE_URL=postgres://fiscal_runtime:REPLACE@127.0.0.1:5432/fiscal?sslmode=require

# --- .env.migrate.local → /etc/bwb-modulo-fiscal/migrate.env (migration role only) ---
# FISCAL_DATABASE_DRIVER=postgres
# FISCAL_DATABASE_URL=postgres://fiscal_migrate:REPLACE@127.0.0.1:5432/fiscal?sslmode=require

# --- .env.admin.local → /etc/bwb-modulo-fiscal/admin.env (admin role; never systemd) ---
# Allowlist: only FISCAL_DATABASE_DRIVER + FISCAL_DATABASE_URL (deploy/admin.env.allowlist).
# Helper reads as root, then env -i + drop-priv to bwb-fiscal-admin. Never log the DSN.
# FISCAL_DATABASE_DRIVER=postgres
# FISCAL_DATABASE_URL=postgres://fiscal_admin:REPLACE@127.0.0.1:5432/fiscal?sslmode=require
